PHOENIX_ENV=local
PHOENIX_HOST=127.0.0.1
PHOENIX_PORT=3000
PHOENIX_LOG_LEVEL=info
PHOENIX_DATABASE_REQUIRED=false
PHOENIX_DATABASE_URL=postgres://phoenix:phoenix@localhost:5432/phoenix
PHOENIX_IDENTITY_SESSION_TTL_SECONDS=2592000
PHOENIX_IDENTITY_RATE_LIMIT_WINDOW_SECONDS=900
PHOENIX_IDENTITY_REGISTER_MAX_ATTEMPTS=5
PHOENIX_IDENTITY_LOGIN_MAX_ATTEMPTS=10
