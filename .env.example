PHOENIX_ENV=local
PHOENIX_HOST=127.0.0.1
PHOENIX_PORT=3000
PHOENIX_LOG_LEVEL=info
PHOENIX_DATABASE_REQUIRED=false
PHOENIX_DATABASE_URL=postgres://phoenix:phoenix@localhost:5432/phoenix
PHOENIX_DOCUMENTATION_ENABLED=true
PHOENIX_REQUIRE_TLS=false
PHOENIX_TRUST_PROXY_HOPS=0
PHOENIX_IDENTITY_SESSION_ABSOLUTE_TTL_SECONDS=2592000
PHOENIX_IDENTITY_SESSION_IDLE_TTL_SECONDS=43200
PHOENIX_IDENTITY_VERIFICATION_TTL_SECONDS=86400
PHOENIX_IDENTITY_PASSWORD_RESET_TTL_SECONDS=900
PHOENIX_IDENTITY_RATE_LIMIT_WINDOW_SECONDS=900
PHOENIX_IDENTITY_REGISTER_MAX_ATTEMPTS=5
PHOENIX_IDENTITY_LOGIN_MAX_ATTEMPTS=10
PHOENIX_IDENTITY_ACTION_REQUEST_MAX_ATTEMPTS=5
PHOENIX_IDENTITY_ACTION_CONFIRM_MAX_ATTEMPTS=10
PHOENIX_IDENTITY_TOKEN_PEPPER=<generate-at-least-32-random-bytes-as-base64url>
PHOENIX_IDENTITY_NOTIFICATION_KEY=<generate-32-random-bytes-as-base64url>
PHOENIX_IDENTITY_PRIVACY_KEY=<generate-at-least-32-random-bytes-as-base64url>
PHOENIX_IDENTITY_MFA_KEY=<generate-separate-32-random-bytes-as-base64url>
PHOENIX_IDENTITY_RECENT_AUTH_SECONDS=600
PHOENIX_IDENTITY_MFA_TRANSACTION_TTL_SECONDS=300
PHOENIX_IDENTITY_MFA_MAX_ATTEMPTS=5
PHOENIX_IDENTITY_TOTP_ENROLLMENT_TTL_SECONDS=600
PHOENIX_IDENTITY_TOTP_ISSUER=Phoenix
PHOENIX_IDENTITY_WEBAUTHN_RP_NAME=Phoenix
PHOENIX_IDENTITY_WEBAUTHN_RP_ID=localhost
PHOENIX_IDENTITY_WEBAUTHN_ORIGINS=http://localhost:3000
PHOENIX_IDENTITY_WEBAUTHN_CHALLENGE_TTL_SECONDS=300
PHOENIX_IDENTITY_WEBAUTHN_TIMEOUT_MS=60000
PHOENIX_IDENTITY_PASSWORD_BREACH_MODE=disabled
PHOENIX_IDENTITY_PWNED_PASSWORDS_BASE_URL=https://api.pwnedpasswords.com
PHOENIX_IDENTITY_PWNED_PASSWORDS_TIMEOUT_MS=3000
PHOENIX_NOTIFICATION_PROVIDER_URL=https://notification-provider.example/v1/deliver
PHOENIX_NOTIFICATION_PROVIDER_TOKEN=<provider-token>
PHOENIX_NOTIFICATION_FROM_EMAIL=security@example.com
PHOENIX_NOTIFICATION_PROVIDER_TIMEOUT_MS=5000
PHOENIX_NOTIFICATION_WORKER_BATCH_SIZE=25
PHOENIX_NOTIFICATION_WORKER_MAX_ATTEMPTS=8
PHOENIX_NOTIFICATION_WORKER_POLL_MS=5000
PHOENIX_NOTIFICATION_WORKER_ONCE=false

# Phase C operations and validation
PHOENIX_OPERATIONS_ENABLED=false
PHOENIX_OPERATIONS_TOKEN=<generate-at-least-32-random-bytes-as-base64url>
PHOENIX_OPERATIONS_OBSERVATION_WINDOW_MINUTES=15
PHOENIX_OPERATIONS_STALE_LOCK_SECONDS=300
PHOENIX_OPERATIONS_MAX_DEAD_LETTERS=0
PHOENIX_OPERATIONS_MAX_STALE_LOCKS=0
PHOENIX_OPERATIONS_MAX_DENIED_EVENTS=100
PHOENIX_PASSKEY_VALIDATION_ENABLED=false

# Key-rotation operator inputs; never persist real values in this file
PHOENIX_IDENTITY_NOTIFICATION_KEY_NEW=<new-32-byte-base64url-key>
PHOENIX_IDENTITY_MFA_KEY_NEW=<new-32-byte-base64url-key>
PHOENIX_KEY_ROTATION_APPLY=false
PHOENIX_KEY_ROTATION_CONFIRM=<ROTATE_IDENTITY_KEYS-only-during-approved-change>

# Explicit notification provider smoke test
PHOENIX_NOTIFICATION_SMOKE_TO=<controlled-test-mailbox>
PHOENIX_NOTIFICATION_SMOKE_CONFIRM=<SEND_TEST_NOTIFICATION-only-during-approved-test>
