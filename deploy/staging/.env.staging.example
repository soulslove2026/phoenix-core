# Non-secret staging configuration. Copy outside the repository and replace every placeholder.
PHOENIX_IMAGE=ghcr.io/replace/phoenix-core@sha256:replace
PHOENIX_DEPLOYMENT_ID=staging-20260715-001
PHOENIX_REGION=eu-west-1
PHOENIX_BUILD_COMMIT=replace-with-lowercase-git-sha
PHOENIX_STAGING_APP_PORT=3000
PHOENIX_STAGING_SECRETS_DIR=/opt/phoenix/staging/secrets

PHOENIX_STAGING_DATABASE_USER=phoenix_staging
PHOENIX_STAGING_DATABASE_NAME=phoenix_staging

PHOENIX_IDENTITY_WEBAUTHN_RP_NAME=Phoenix Staging
PHOENIX_IDENTITY_WEBAUTHN_RP_ID=staging.example.com
PHOENIX_IDENTITY_WEBAUTHN_ORIGINS=https://staging.example.com

# Enable only during an approved Passkey assurance ceremony, then return to false.
PHOENIX_PASSKEY_VALIDATION_ENABLED=false

# Optional notification-worker profile values.
PHOENIX_NOTIFICATION_PROVIDER_URL=https://provider.example.test/send
PHOENIX_NOTIFICATION_FROM_EMAIL=no-reply@staging.example.com
