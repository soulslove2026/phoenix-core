{
  "name": "@phoenix/core",
  "version": "3.2.0",
  "private": true,
  "description": "Phoenix Core production-stack migration baseline",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "check": "tsc --noEmit && node scripts/repository-check.mjs",
    "test": "tsx --test test/**/*.test.ts",
    "test:coverage": "tsx --test --experimental-test-coverage test/**/*.test.ts",
    "audit": "npm audit --omit=dev",
    "verify": "npm run check && npm test && npm run build"
  },
  "dependencies": {
    "@fastify/swagger": "9.8.0",
    "@fastify/swagger-ui": "6.1.0",
    "fastify": "5.10.0",
    "fastify-plugin": "5.1.0",
    "pg": "8.16.3"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/pg": "8.15.5",
    "tsx": "4.23.1",
    "typescript": "5.9.3"
  }
}
