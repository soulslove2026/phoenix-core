{
  "name": "@phoenix/core",
  "version": "3.4.0",
  "private": true,
  "description": "Phoenix Identity Slice 2: verification, recovery, and session hardening",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/main.js",
    "typecheck": "tsc -p tsconfig.check.json --noEmit",
    "check:repo": "node scripts/repository-check.mjs",
    "check": "npm run typecheck && npm run check:repo && npm run security:check",
    "test": "tsx --test test/*.test.ts",
    "test:integration": "tsx --test test/integration/*.test.ts",
    "test:all": "npm test && npm run test:integration",
    "test:coverage": "tsx --test --experimental-test-coverage test/*.test.ts",
    "audit": "npm audit --omit=dev",
    "verify": "npm run check && npm test && npm run build",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:compiled": "node dist/scripts/migrate.js",
    "security:check": "node scripts/security-check.mjs"
  },
  "dependencies": {
    "@fastify/swagger": "9.8.0",
    "@fastify/swagger-ui": "6.1.0",
    "fastify": "5.10.0",
    "fastify-plugin": "6.0.0",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/pg": "8.20.0",
    "tsx": "4.23.1",
    "typescript": "5.9.3"
  }
}
